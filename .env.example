DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Alibaba Bailian / DashScope Qwen-VL vision MCP.
# Leave the API key blank here; put the real key in local .env only.
QWEN_VL_API_KEY=
QWEN_VL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_VL_MODEL=qwen3-vl-plus

# Backward-compatible generic vision env names.
VISION_API_KEY=
VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VISION_MODEL=qwen3-vl-plus
VISION_MAX_IMAGE_BYTES=10485760
VISION_OFFLINE=0
